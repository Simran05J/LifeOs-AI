# ──────────────────────────────────────────────────────────
# LifeOS AI — root .gitignore
# ──────────────────────────────────────────────────────────

# Environment secrets — NEVER commit these
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
backend/.env
backend/.env.local

# Node / Vite
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Python / FastAPI backend
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
backend/__pycache__/
backend/*.egg-info/
backend/.venv/
backend/venv/
backend/.pytest_cache/
*.pyc

# IDE / OS
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# Firebase service-account key (if ever downloaded locally)
*service-account*.json
*serviceAccountKey*.json
*firebase_credentials.json*
