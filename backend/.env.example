# =============================================================================
# LifeOS AI — Backend Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your real values before running the server.
# NEVER commit .env with real secrets to version control.
# =============================================================================


# ── App Configuration ─────────────────────────────────────────────────────────
PROJECT_NAME="AI Life OS Backend"
PROJECT_VERSION="1.0.0"
APP_ENV="development"
ENVIRONMENT="development"
DEBUG=True
API_V1_STR="/api/v1"
LOG_LEVEL="INFO"


# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-secret-key-for-jwt-signing"
ACCESS_TOKEN_EXPIRE_MINUTES=11520


# ── Gemini AI ─────────────────────────────────────────────────────────────────
# ⚠️  REQUIRED — The app will fail to call Gemini without this.
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"


# ── Firebase Configuration ────────────────────────────────────────────────────
# ⚠️  REQUIRED — At least one of the two credential options below must be set.
#
# Option A (recommended for local dev): path to the downloaded service-account JSON file.
#   Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH="app/firebase/firebase_credentials.json"
#
# Option B: paste the entire service-account JSON as a single-line string.
FIREBASE_CREDENTIALS_JSON='{"type": "service_account", "project_id": "...", ...}'
#
# Your Firebase project ID (found in Firebase Console → Project Settings → General)
FIREBASE_PROJECT_ID="your-firebase-project-id"
#
# Only required if you use the Firebase Realtime Database (not Firestore).
FIREBASE_DATABASE_URL="https://your-project-id.firebaseio.com"


# ── CORS & Rate Limiting ──────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
RATE_LIMIT_PER_MINUTE=120
